# NPT Bulk Equilibration + Sphere/Cube Extraction Configuration
# Density target from stage13 optimization (config_stage13.env)
# Date: 2026-04-01  (updated: 20 Å sphere / 40 Å cube geometry)

# Physical setup - TARGET DENSITY FROM OPTIMIZATION
export RHO0_MOL_A3="0.037235960250849326"           # mol/Å³ (exact from stage13 optimization)
export RHO_GCC="1.11391659"                         # g/cm³ equivalent
export DR_A="0.25"                                  # Shell thickness

# Bulk NPT setup (scaled for representative statistics)
export N_WATER_BULK="3800"                          # Bulk water molecules (~35 Å box edge)
export ALANINE_PDB="systems/ala2_seed.pdb"         # Alanine dipeptide source
export ATOM_OVERLAP_CUTOFF="1.6"                   # Å, MC packing cutoff

# Temperature and pressure control
export TEMP_K="300.0"                               # NVT/NPT target temperature
export PRESS_BAR="1.01325"                              # NPT target pressure (bar, for units metal)

# LAMMPS simulation parameters
export DT_FS="1.0"                                  # Timestep in fs
export THERMOSTAT_TDAMP="0.1"                       # ps, Langevin/NPT thermostat damping
export BAROSTAT_PDAMP="1.0"                         # ps, NPT barostat damping

# Phase durations (steps)
export STEPS_MINIMIZE="10000"                       # Energy minimization
export STEPS_WARMUP="100000"                        # T=25K warmup (100 ps)
export STEPS_EQ_NPT="500000"                        # NPT equilibration (500 ps)
export STEPS_PROD_NPT="500000"                      # NPT production (500 ps)

# Alanine solute constraints
export SOLUTE_FIXED="yes"                           # Fully frozen (zero velocity, COM locked)
export SOLUTE_FREEZE_GROUP="1"                      # molecule ID 1 = alanine

# Restart checkpoints (output every N steps)
export RESTART_STRIDE="50000"                       # Restart at 50k, 100k, 150k, ...

# Sphere/cube extraction parameters  (20 Å sphere / 40 Å cube)
export SPHERE_R_A="20.0"                            # 20 Å sphere for NPBC
export CUBE_EDGE_A="40.0"                           # 40 Å cube enclosing the 20 Å sphere

# Extraction centering
export EXTRACT_CENTER="solute_com"                  # Center on alanine COM
export EXTRACT_PADDING_A="1.0"                      # Extra clearance for bounds

# Output density validation
export DENSITY_RTOL="0.01"                          # Relative tolerance for validation (unused)

# Extracted-system equilibration
export STEPS_EQ_EXTRACTED="100000"                  # 100 ps NVT eq for extracted systems (at 1 fs)
export STEPS_PROD_EXTRACTED="5000000"               # 5 ns NVT production for extracted systems

# NPBC bias files  (MANDATORY for NPBC — must point to 20 Å bias)
# Set these to the paths of your R=20 Å optimised bias files before running NPBC.
# The workflow will fail fast if they are unset or missing.
export NPBC_VDWPARM_FILE=""                         # e.g. "./bias/VDWPARM_R20_....dat"
export NPBC_GAU_FILE=""                             # e.g. "./bias/gau_R20.dat"

# Environment
export MACE_VENV_PATH="/leonardo/home/userexternal/gbasile0/mace_glob"
export PYLIBDIR="/leonardo/prod/spack/06/install/0.22/linux-rhel8-icelake/gcc-8.5.0/python-3.11.7-ziwh63aulhhzxksf42k5u3gnim2rbpmp/lib"
export CONDA_ENV_NAME="mace_new"                    # Legacy name; MACE_VENV_PATH is preferred on Leonardo
export PYTHON_MODULE=""                             # Use mace_glob venv; set to python/3.11.7 only if needed
export GCC_MODULE=""                                # OpenMPI module below supplies the matching GCC/CUDA runtime
export CUDA_MODULE="cuda/12.6"
export CMAKE_MODULE="cmake/3.27.7"
export MPI_MODULE="openmpi/4.1.6--gcc--12.2.0-cuda-12.2"
export MKL_MODULE="intel-oneapi-mkl/2023.2.0"
export GSL_MODULE="gsl/2.7.1--oneapi--2023.2.0"
export PLUMED_ROOT="/leonardo/home/userexternal/gbasile0/local/plumed-2.9.4"
export LAMMPS_ROOT="/leonardo/home/userexternal/gbasile0/local/lammps-MOL-dev"
export LEONARDO_MODULE_PURGE="1"
export CUDA_VISIBLE_DEVICES="0"                     # Modify as needed for Leonardo
export OMP_NUM_THREADS="1"
export LMP_BIN="/leonardo/home/userexternal/gbasile0/local/lammps-MOL/bin/lmp"
export LMP_LIBRARY_PATH="/leonardo/home/userexternal/gbasile0/local/lammps-MOL-dev/lib64"
export MODEL_FILE="MACE-OFF23_small.model-mliap_lammps_float32.pt"

# Build/output options
export RANDOM_SEED="12345"                          # Reproducibility
export VERBOSE="1"                                  # Debug output
